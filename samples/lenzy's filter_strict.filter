Style #Style for Rare items
	Rarity == "Rare"
	ItemType "Any Armor" "Any Weapon" "Any Shield" "Jewelry" "Bow Quivers" "Crossbow Quivers" "Jewels" "Potions"
	SetBorderColor 255 255 000
	
Style #Style for Magic items
	Rarity == "Magic"
	ItemType "Any Armor" "Any Weapon" "Any Shield" "Jewelry" "Bow Quivers" "Crossbow Quivers" "Jewels" "Potions"
	SetBorderColor 065 105 225
	
Style #Style for Normal items
	Rarity == "Normal"
	ItemType "Any Armor" "Any Weapon" "Any Shield" "Jewelry" "Bow Quivers" "Crossbow Quivers" "Jewels" "Potions"
	SetBorderColor 255 255 255
	
Style #Mysterious rift bases Elite uniques - Enter any base you want after ItemName
	ItemName "Spiderweb Sash" "Champion Sword" "Colossus Blade" "Corona" "War Pike" "Hydra Bow" "Matriarchal Javelin" "Sacred Armor" "Spired Helm" "Shako" "Heavy Bracers"
	Rarity == "Normal"
	PrependText "{Gold}[Mysterious] "
	SetFont "Font16"

Style
	Tier == Elite
	PrependText "[Elite] "
	SetBorderColor 130 233 240

Style #Ethereal Items
	Ethereal == True
	PrependText "[ETH] "
	
Style #Show Implicit Tier 1
	ImplicitTier == 1
	Rarity == "Unique"
	Tier == Elite
	PrependText "{Red}[T1] "	
	
Style #Show Implicit Tier 1
	Rarity == "Unique"
	Tier == Exceptional
	PrependText "[Exceptional] "
	
Style #Show Implicit Tier 1
	ImplicitTier == 1
	Rarity == "Unique"
	Tier == Exceptional
	PrependText "{Red}[T1] "
	
Style #Show Implicit Tier 1
	ImplicitTier == 1
	Rarity == "Unique"
	Tier == Normal
	PrependText "{Red}[T1] "	
	
Style #Show Implicit Tier 1
	ImplicitTier == 1
	Rarity <= "Rare"
	PrependText "{Red}[T1] "
	
Style #Show Implicit Tier 2
	ImplicitTier == 2
	PrependText "[T2] "
	
Style #Show Implicit Tier 3
	ImplicitTier == 3
	ItemType "Rings" "Amulets"
	PrependText "[T3] "
	
Style #Show Implicit Tier 4
	ImplicitTier == 4
	ItemType "Rings" "Amulets"
	PrependText "[T4] "

Style #Showing ItemLevel
	ItemLevel >= 85
	ItemType "Any Armor" "Any Weapon" "Any Shield" "Jewelry"
	AppendText " {Red}({ItemLevel})"
	
#Style #Showing ItemLevel
#	ItemLevel <= 84
#	AppendText " ({ItemLevel})"

Style #Other Runes
	ItemType "Runes"
	SetBorderColor 255 165 000
	SetBlendMode "Alpha75"
	
Style #Other Runes
	ItemType "Runes"
	SetBorderColor 255 165 000
	SetBlendMode "Alpha75"
	PlayerLevel < 41
	ChatNotification "{Original}"

