#===============================================================================================================
# LeNzY's Annihilus Filter
#===============================================================================================================
# VERSION:  0.5.4-beta
# PATCH:	December 25 2025
# TYPE:     Strict
# STYLE:	Default
#
#------------------------------------
# LINKS TO HELP WITH FILTER EDITING
#------------------------------------
#
# ANNIHILUS:					https://annihilus.net/
# ANNIHILUS WIKI:				https://annihilus.net/wiki/index.php/Main_Page
# ANNIHILUS FILTER WIKI: 		https://annihilus.net/wiki/index.php/Item_Filter
#
#------------------------------------
# INSTALLATION / UPDATE :
#------------------------------------
#
# 1a) INGAME: Enter a game in Annihilus SotR, ESC -> Options -> Gameplay -> Show Folder (under the "Item Filter" section)
# 1b) Localize your Annihilus folder on your PC example: C:\Program Files (x86)\Annihilus\Apps\AnnihilusBeta\filters
# 2)  Paste this file into the folder
# 
#
#------------------------------------
# CONTACT - if you need to get in touch with me:
#------------------------------------
#
#
# TWITCH:  https://www.twitch.tv/lenzyfly
# YOUTUBE: https://www.youtube.com/LeNzYFly
# DISCORD: lenzy
#
#
#===============================================================================================================
# Filtration Options
#===============================================================================================================
#
# PlayAlertSound
# 0 = very soft click / 1 = select hammer sound / 4 = soft click / 6 = level up / 7 = merc level up / 8 = item breaking  
# 9 = eerie whir / 10 = cube / 11 = higher pitched whir / 12 = scroll identify / 13 = quest complete / 14 = repair
# 15 = hostile / 16 = low woosh / 17 =  high woosh 1 / 18 =  high woosh 2 / 19 = high woosh 3 / 20 = gold
#
# SetFont
# Font6     		Font8        	Font16        Font24        Font30        Font30    
# FontFormal10      FontFormal11    FontFormal12    
# FontExocet8       FontExocet10    
# FontRidiculous    ReallyTheLastSucker        	  FontInGameChat
#
# SetBlendMode
# Alpha25    	Alpha50     Alpha75    		Alpha50Bright 
# Inverted 		Normal 		Alpha25Bright   Bright
#
# SetTextColor
# LightGreen	Green		DarkGreen	Yellow		Orange		Red		Blue	Purple		
# White			White2  	DarkWhite   DarkGold 	Gold		Grey 	Black 	Black2
#===============================================================================================================
# Styles - Following codes can be used in {} for effects in PrepentText, AppendText and SetItemName
# ItemName	ItemLevel	Runeword	Sockets Original
# Red	Green	Blue	Purple	Orange	Gold
# Tan	White	Yellow	Color	Break
#===============================================================================================================
# General Style - Append and Prepend - Ethereal, Tiers, Itemlevels etc.
#===============================================================================================================

Show #Shows all items in town no matter what.
	AreaLevel == 0

Style #Riftstone Tier 1
	ItemType "Riftstone"
	RiftstoneTier == 1
	PrependText "{Purple}[T1] "
	SetBackgroundColor 25 25 25
	SetBorderColor 200 0 200
	SetFont "Font16"
	SetItemName "{Purple}{Original}"
	SetBlendMode "Alpha75"
	PlayAlertSound 11
	MinimapIcon 2 200 0 200
#	ChatNotification "{Original}"
	
Style #Riftstone Tier 2
	ItemType "Riftstone"
	RiftstoneTier == 2
	PrependText "{Purple}[T2] "
	SetBackgroundColor 25 25 25
	SetBorderColor 200 0 200
	SetFont "Font16"
	SetItemName "{Purple}{Original}"
	SetBlendMode "Alpha75"
#	ChatNotification "{Original}"
	
Style #Riftstone Tier 3
	ItemType "Riftstone"
	RiftstoneTier == 3
	PrependText "{Purple}[T3] "
	SetBackgroundColor 25 25 25
	SetBorderColor 200 0 200
	SetFont "Font16"
	SetItemName "{Purple}{Original}"
	SetBlendMode "Alpha75"
	PlayAlertSound 11
	MinimapIcon 2 200 0 200
	ChatNotification "{Original}"
	
Style #Riftstone Tier 4
