# Magic Items
#===============================================================================================================

Show
	ItemType "Any Weapon" "Any Shield" "Class Specific" "Helmets" "Circlets" "Body Armors" "Jewels"
	AffixCount >= 2
	PrefixTier == 1
	SuffixTier == 1

Style
	ItemType "Any Weapon" "Any Shield" "Class Specific" "Helmets" "Circlets" "Body Armors"
	Rarity == "Magic"
	AffixCount >= 2
	PrefixTier == 1
	SuffixTier == 1
	SetBorderColor 200 0 200
	SetFont "Font16"
	PrependText "{Red}[2x T1 MODS] "
	SetBlendMode "Alpha75"
    PlayAlertSound 11
	MinimapIcon 2 200 0 200
	
Show
	ItemType "Jewels"
	AffixCount == 1
	PrefixTier == 1	

