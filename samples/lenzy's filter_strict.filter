#===============================================================================================================
# Unique & Set Items - Style
#===============================================================================================================

Style #Style normal uniques
	Rarity == "Unique"
	Tier == "Normal"
	ItemType "Any Weapon" "Any Armor" "Any Shield" "Belts" "Bow Quivers" "Crossbow Quivers"
	SetTextColor "Gold"
	SetFont "Font24"
	SetBlendMode "Alpha75"
	SetItemName "{Original}"
	
Style #Style exceptional uniques
	Rarity == "Unique"
	Tier == "Exceptional"
	SetBorderColor 255 127 80
	SetTextColor "Gold"
	SetFont "Font30"
	SetBlendMode "Alpha75"

Style #Style elite uniques
	Rarity == "Unique"
	Tier == "Elite"
	SetTextColor "Orange"
	SetFont "Font42"
	SetBlendMode "Alpha75"
	SetBackgroundColor 200 200 200
	SetBorderColor 255 127 80
	
Style #Style Unique Riftstones
	ItemType "Riftstone"
	Rarity == "Unique"
	SetBackgroundColor 200 200 200
	SetBorderColor 170 0 170
	SetTextColor "Purple"
	SetFont "Font42"
	SetBlendMode "Alpha75"
	
Style #Style Unique Rings/Amulets
	ItemType "Rings" "Amulets"
	Rarity == "Unique"
	SetTextColor "Gold"
	SetFont "Font24"
	SetItemName "{Original}"
	SetBlendMode "Alpha75"
	
Style #Style Unique Jewels
	ItemType "Jewels"
	Rarity == "Unique"
	SetTextColor "Gold"
	SetFont "Font42"
	SetBlendMode "Alpha75"
	SetBackgroundColor 200 200 200
	SetBorderColor 255 127 80
	
Style #Style set items
	Rarity == "Set"
	SetBorderColor 0 255 0
	SetTextColor "Green"
    SetFont "Font42"
    SetBlendMode "Alpha75"
    PlayAlertSound 7
	MinimapIcon 2 0 255 0
	
#===============================================================================================================
# Unique & Set Items - Style - Chat notifications - Unidentified
#===============================================================================================================	
	
Style
	Identified == False
	Rarity == "Unique"
	Tier == "Normal"
	ItemType "Any Weapon" "Any Armor" "Any Shield" "Belts" "Bow Quivers" "Crossbow Quivers"
	ChatNotification "{Purple}* {Original} {Purple}*"
	
Style
	Identified == False
	Rarity == "Unique"
	Tier == "Exceptional"
	ChatNotification "{Purple}** {Original} {Purple}**"
	
Style
	Identified == False
	Rarity == "Unique"
	Tier == "Elite"
	ChatNotification "{Purple}*** {Original} {Purple}***"
	
Style # Amulets, Rings, Jewels
	Identified == False
	Rarity == "Unique"
	Tier == "Normal"
	Width == 1
	Height == 1
	ChatNotification "{Purple}*** {Original} {Purple}***"
	
