#===============================================================================================================
# Item Bases - Leveling
#===============================================================================================================

Show
	Rarity == "Magic"
	PrefixTier <= 1
	SuffixTier <= 1

Hide #All rings, amulets and quivers that are "magic" aka blue - After ilvl 20 magic rarity items will no longer show and only normal and rares from there on
	ItemType "Rings" "Amulets" "Bow Quivers" "Crossbow Quivers"
	Rarity == "Magic"
	ItemLevel > 21
	
Hide #Attack Weapons "normal bases" - After ilvl 30 magic rarity items will no longer show, only higher bases will appear
	ItemType "Hand to Hand" "Amazon Javelins" "Amazon Spears" "Amazon Bows" "Scepters" "Axes" "Clubs" "Knives" "Polearms" "Hammers" "Spears" "Maces" "Blunt Weapons" "Bows" "Crossbow" "Javelins" "Throwing Knives" "Throwing Axes"
	Rarity == "Magic"
	Tier == "Normal"
	ItemLevel > 31

Hide #Attack Weapons "normal bases" - After ilvl 74 rare rarity items will no longer show, only higher bases will appear
	ItemType "Amazon Spears" "Scepters" "Clubs" "Knives" "Polearms" "Spears" "Blunt Weapons" "Crossbow" "Throwing Knives" "Throwing Axes"
	Rarity == "Rare"
	Tier == "Normal"
	ItemLevel > 74

Hide #Low bases "normal bases" - After ilvl 30 magic rarity items will no longer show, only higher bases will appear
	ItemType "Amazon Bows" "Amazon Javelins" "Amazon Spears" "Axes" "Belts" "Blunt Weapons" "Body Armors" "Boots" "Bows" "Cloaks" "Clubs" "Crossbow" "Hammers" "Hand to Hand" "Helmets" "Javelins" "Knives" "Maces" "Polearms" "Scepters" "Shields" "Spears" "Swords" "Throwing Axes" "Throwing Knives"
	Rarity == "Magic"
	Tier == "Normal"
	ItemLevel > 31

Hide #Low bases "normal bases" - After ilvl 44 normal rarity items will no longer show, only higher bases will appear
	ItemType "Amazon Bows" "Amazon Javelins" "Amazon Spears" "Axes" "Belts" "Blunt Weapons" "Body Armors" "Boots" "Bows" "Cloaks" "Clubs" "Crossbow" "Hammers" "Hand to Hand" "Helmets" "Javelins" "Knives" "Maces" "Polearms" "Scepters" "Shields" "Spears" "Swords" "Throwing Axes" "Throwing Knives"
	Rarity == "Normal"
	Tier == "Normal"
	ItemLevel > 44
	
Hide #Low bases "normal bases" - After ilvl 74 rare rarity items will no longer show, only higher bases will appear
	ItemType "Amazon Spears" "Blunt Weapons" "Body Armors" "Cloaks" "Clubs" "Crossbow" "Knives" "Maces" "Polearms" "Scepters" "Spears" "Throwing Axes" "Throwing Knives"
	Rarity == "Rare"
	Tier == "Normal"
	ItemLevel > 74

Hide #Attack Weapons "exceptional bases" - After ilvl 74 exceptional rare rarity items will no longer show, only higher bases will appear
	ItemType "Amazon Spears" "Scepters" "Clubs" "Knives" "Polearms" "Hammers" "Spears" "Maces" "Blunt Weapons" "Crossbow" "Throwing Knives" "Throwing Axes"
	Rarity <= "Rare"
	Tier == "Normal"
	ItemLevel > 74
	
Hide #All bases "exceptional bases" - After ilvl 60 exceptional magic rarity items will no longer show, only higher bases will appear
	ItemType "Amazon Bows" "Amazon Javelins" "Amazon Spears" "Auric Shields" "Axes" "Belts" "Blunt Weapons" "Body Armors" "Boots" "Bows" "Cloaks" "Clubs" "Crossbow" "Gloves" "Hammers" "Hand to Hand" "Helmets" "Javelins" "Knives" "Maces" "One Handed Weapons" "Orbs" "Pelts" "Polearms" "Primal Helmets" "Scepters" "Shields" "Spears" "Staves" "Throwing Axes" "Throwing Knives" "Two Handed Weapons" "Voodoo Heads" "Wands"
	Rarity == "Magic"
	Tier <= "Exceptional"
	ItemLevel > 61

Hide #Medium bases "exceptional bases" - After ilvl 74 exceptional normal rarity items of these item types will no longer show, only higher bases will appear
	ItemType "Amazon Bows" "Amazon Javelins" "Amazon Spears" "Axes" "Blunt Weapons" "Body Armors" "Bows" "Cloaks" "Clubs" "Crossbow" "Hammers" "Hand to Hand" "Javelins" "Knives" "Maces" "One Handed Weapons" "Pelts" "Polearms" "Scepters" "Shields" "Spears" "Throwing Axes" "Throwing Knives" "Two Handed Weapons"
