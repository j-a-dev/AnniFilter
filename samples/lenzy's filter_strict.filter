#===============================================================================================================
# Vendor Pickups
#===============================================================================================================

Show #Vendor for Fractured Rift Energy - Gives 10 Fractures
	Sockets == 6
	Rarity == "Normal"
	SetItemName "{Red}[10x Frac] {Original}"
	SetBorderColor 255 50 255
	SetTextColor Red
	SetBlendMode "Alpha50"
	SetFont "Font24"
	ChatNotification "{Original}"
	
Show #Vendor for Fractured Rift Energy - 2x3 - Gives 5 Fractures
	Sockets == 5
	Rarity == "Normal"
	Width == 2
	Height == 3 
	SetItemName "{Red}[5x Frac] {Original}"
	SetBorderColor 255 50 255
	SetTextColor Red
	SetBlendMode "Alpha75"
	SetFont "Font16"
	
Show #Vendor for Fractured Rift Energy - 2x4 - Gives 5 Fractures
	Sockets == 5
	Rarity == "Normal"
	Width == 2
	Height == 4 
	SetItemName "{Red}[5x Frac] {Original}"
	SetBorderColor 255 50 255
	SetTextColor Red
	SetBlendMode "Alpha75"
	SetFont "Font16"
	
Hide #Vendor for Fractured Rift Energy - 2x2 - Gives 3 Fractures
	Sockets >= 3	
	Rarity == "Normal"
	Width == 2
	Height == 2 
	SetItemName "{Red}[3x Frac] {Original}"
	SetBorderColor 255 50 255
	SetTextColor Red
	SetBlendMode "Alpha75"
	PlayerLevel >= 90
	
